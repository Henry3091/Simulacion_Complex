{
  "proyecto": "Complexivo App - Spring Boot + Security + Thymeleaf + MySQL",
  "orden_ejecucion": [

    {
      "paso": 1,
      "nombre": "Crear proyecto en Spring Initializr",
      "configuracion": {
        "group": "com.desarrollo",
        "artifact": "complexivo-app",
        "dependencias": [
          "Spring Web",
          "Spring Boot DevTools",
          "Spring Security",
          "Spring Data JPA",
          "MySQL Driver",
          "Thymeleaf"
        ]
      }
    },

    {
      "paso": 2,
      "nombre": "Configurar application.properties",
      "archivo": "src/main/resources/application.properties",
      "codigo": "spring.application.name=complexivo-app\nspring.datasource.url=jdbc:mysql://localhost:3306/complexivo\nspring.datasource.username=root\nspring.datasource.password=mio123*\nspring.jpa.hibernate.ddl-auto=update\nspring.jpa.database-platform=org.hibernate.dialect.MySQLDialect"
    },

    {
      "paso": 3,
      "nombre": "Crear base de datos MySQL",
      "codigo_sql": "CREATE DATABASE complexivo;"
    },

    {
      "paso": 4,
      "nombre": "Crear paquetes",
      "paquetes": [
        "config",
        "controllers",
        "models",
        "repository",
        "services"
      ]
    },

    {
      "paso": 5,
      "nombre": "Crear entidades",
      "descripcion": "User, Role, Product, Category con sus relaciones",
      "detalle": [
        "User -> ManyToMany con Role",
        "Product -> ManyToOne con Category",
        "Category -> OneToMany con Product"
      ]
    },

    {
      "paso": 6,
      "nombre": "Crear repositorios",
      "interfaces": [
        "UserRepository",
        "RoleRepository",
        "ProductRepository",
        "CategoryRepository"
      ]
    },

    {
      "paso": 7,
      "nombre": "Crear servicios base",
      "servicios": [
        "UserService",
        "ProductService",
        "CategoryService"
      ]
    },

    {
      "paso": 8,
      "nombre": "Implementar UserDetailsService",
      "archivo": "UserDetailsServiceImpl.java",
      "funcion": "Cargar usuario desde base de datos con roles",
      "nota": "Convierte roles a SimpleGrantedAuthority"
    },

    {
      "paso": 9,
      "nombre": "Configurar Security",
      "archivo": "SecurityConfig.java",
      "funcionalidades": [
        "Login personalizado /login",
        "Acceso público a /login y /register",
        "Ruta / protegida con roles USER y ADMIN",
        "Logout en /logout",
        "Password encriptado con BCrypt",
        "Autenticación con UserDetailsServiceImpl"
      ]
    },

    {
      "paso": 10,
      "nombre": "Controlador de autenticación",
      "archivo": "AuthController.java",
      "funcionalidades": [
        "Mostrar login",
        "Evitar login si ya está autenticado",
        "Cerrar sesión manual"
      ]
    },

    {
      "paso": 11,
      "nombre": "Controlador de usuario",
      "archivo": "UserController.java",
      "funcionalidades": [
        "Registro de usuario",
        "Asignación automática de ROLE_USER",
        "Validación de usuario duplicado"
      ]
    },

    {
      "paso": 12,
      "nombre": "Controlador de productos",
      "archivo": "ProductController.java",
      "funcionalidades": [
        "Listar productos en /",
        "Agregar producto",
        "Editar producto",
        "Eliminar producto",
        "Mostrar categorías en formulario",
        "Obtener rol del usuario autenticado"
      ]
    },

    {
      "paso": 13,
      "nombre": "Crear vistas Thymeleaf",
      "archivos": [
        "auth/login.html",
        "auth/register.html",
        "product/home.html",
        "product/add-product.html"
      ],
      "nota": "Usar Bootstrap para diseño"
    },

    {
      "paso": 14,
      "nombre": "IMPORTANTE - CSRF",
      "descripcion": "Spring Security ya lo maneja automáticamente en Thymeleaf",
      "nota": "No necesitas agregar input hidden manual porque Thymeleaf lo incluye en th:action"
    },

    {
      "paso": 15,
      "nombre": "Flujo de ejecución",
      "acciones": [
        "Ejecutar aplicación",
        "Ir a /register",
        "Crear usuario",
        "Ir a /login",
        "Iniciar sesión",
        "Acceder a /",
        "Agregar productos",
        "Editar y eliminar productos"
      ]
    },

    {
      "paso": 16,
      "nombre": "Reglas importantes",
      "reglas": [
        "Los roles deben tener formato ROLE_USER o ROLE_ADMIN",
        "Las contraseñas deben guardarse encriptadas",
        "No se puede acceder a / sin login",
        "Solo usuarios autenticados ven productos",
        "Las relaciones deben estar bien definidas en entidades"
      ]
    }

  ]
}