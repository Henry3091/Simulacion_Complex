{
  "orden_ejecucion": [
    {
      "paso": 1,
      "nombre": "Crear proyecto",
      "descripcion": "Crear proyecto con Expo",
      "comando": "npx create-expo-app -t",
      "entrar": "cd nombreProyecto"
    },
    {
      "paso": 2,
      "nombre": "Crear carpetas",
      "descripcion": "Crear estructura del proyecto",
      "carpetas": "Screens, components, firebase, navigations"
    },
    {
      "paso": 3,
      "nombre": "Crear pantallas",
      "descripcion": "Crear archivos principales",
      "archivos": "LoginScreen, RegistroScreen, ListaScreen, GuardarScreen, NotasScreen, InformacionScreen"
    },
    {
      "paso": 4,
      "nombre": "Instalar Firebase",
      "descripcion": "Instalar dependencia",
      "comando": "npm install firebase"
    },
    {
      "paso": 5,
      "nombre": "Configurar Firebase",
      "descripcion": "Crear config.tsx",
      "codigo": "export const auth = getAuth(app); export const db = getDatabase(app);"
    },
    {
      "paso": 6,
      "nombre": "Registro usuario",
      "descripcion": "Crear usuario con Firebase",
      "codigo": "createUserWithEmailAndPassword(auth, correo, contrasenia)"
    },
    {
      "paso": 7,
      "nombre": "Guardar usuario DB",
      "descripcion": "Guardar datos en realtime database",
      "codigo": "set(ref(db, 'usuarios/' + uid), {correo, avatar:nick, edad})"
    },
    {
      "paso": 8,
      "nombre": "Login usuario",
      "descripcion": "Iniciar sesión",
      "codigo": "signInWithEmailAndPassword(auth, correo, contrasenia)"
    },
    {
      "paso": 9,
      "nombre": "Navegacion",
      "descripcion": "Ir al Drawer despues del login",
      "codigo": "navigation.navigate('Drawer')"
    },
    {
      "paso": 10,
      "nombre": "Obtener UID",
      "descripcion": "Leer usuario logueado",
      "codigo": "onAuthStateChanged(auth,(user)=>{ setid(user.uid) })"
    },
    {
      "paso": 11,
      "nombre": "Guardar notas",
      "descripcion": "Guardar nota en Firebase",
      "codigo": "set(ref(db,'usuarios/'+id+'/notas/'+titulo),{titulo,descripcion,fecha})"
    },
    {
      "paso": 12,
      "nombre": "Leer notas",
      "descripcion": "Leer notas desde Firebase",
      "codigo": "onValue(ref(db,'usuarios/'+id+'/notas'),snapshot=>setnotas(snapshot.val()))"
    },
    {
      "paso": 13,
      "nombre": "Mostrar notas",
      "descripcion": "Usar FlatList",
      "codigo": "FlatList data={notas} renderItem={item.descripcion}"
    },
    {
      "paso": 14,
      "nombre": "Leer usuario",
      "descripcion": "Mostrar datos del usuario",
      "codigo": "onValue(ref(db,'usuarios/'+uid),snapshot=>setusuario(snapshot.val()))"
    },
    {
      "paso": 15,
      "nombre": "Cerrar sesion",
      "descripcion": "Logout",
      "codigo": "signOut(auth)"
    },
    {
      "paso": 16,
      "nombre": "Consumir API",
      "descripcion": "Obtener peliculas",
      "codigo": "fetch(API_PELICULAS).then(r=>r.json()).then(json=>setpeliculas(json.peliculas))"
    },
    {
      "paso": 17,
      "nombre": "Mostrar peliculas",
      "descripcion": "Usar FlatList con componente Tarjeta",
      "codigo": "FlatList data={peliculas} renderItem={item=>Tarjeta}"
    },
    {
      "paso": 18,
      "nombre": "Componente Tarjeta",
      "descripcion": "Mostrar imagen y titulo",
      "codigo": "Text + Image + TouchableOpacity"
    },
    {
      "paso": 19,
      "nombre": "Modal",
      "descripcion": "Mostrar detalles",
      "codigo": "Modal visible={ocultar}"
    },
    {
      "paso": 20,
      "nombre": "Switch comentarios",
      "descripcion": "Cambiar positivos y negativos",
      "codigo": "Switch value={positivo} onValueChange"
    },
    {
      "paso": 21,
      "nombre": "Lista comentarios",
      "descripcion": "Mostrar comentarios",
      "codigo": "FlatList data={comentarios}"
    },
    {
      "paso": 22,
      "nombre": "Flujo final",
      "descripcion": "Flujo completo de la app",
      "flujo": "Login -> Registro -> Drawer -> Lista -> Guardar -> Notas -> Informacion"
    }
  ]
}